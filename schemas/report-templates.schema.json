{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/report-templates.schema.json",
  "title": "TraceCue Report Templates",
  "type": "object",
  "required": [
    "schema_version",
    "templates_version",
    "generated_at",
    "locale_selection",
    "baseline_locale",
    "supported_locale_count",
    "template_inventory",
    "selected_templates",
    "locale_templates",
    "fallback",
    "raw_evidence_policy",
    "rendering_contract",
    "boundary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "templates_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "locale_selection": { "type": "string" },
    "baseline_locale": { "type": "string" },
    "supported_locale_count": { "type": "number" },
    "template_inventory": { "type": "array" },
    "selected_templates": { "type": "object" },
    "locale_templates": { "type": "array" },
    "fallback": { "type": "object" },
    "raw_evidence_policy": { "type": "object" },
    "rendering_contract": { "type": "object" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": true
}
