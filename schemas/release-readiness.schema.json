{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/release-readiness.schema.json",
  "title": "TraceCue Release Readiness",
  "type": "object",
  "required": [
    "schema_version",
    "readiness_version",
    "generated_at",
    "status",
    "product_identity",
    "package_metadata",
    "decisions",
    "local_checks",
    "publication_boundary",
    "boundary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "readiness_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "type": "string" },
    "product_identity": { "type": "object" },
    "package_metadata": { "type": ["object", "null"] },
    "decisions": { "type": "object" },
    "local_checks": { "type": "array" },
    "publication_boundary": { "type": "object" },
    "next_steps": { "type": "array" },
    "diagnostics": { "type": "array" },
    "warnings": { "type": "array" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": true
}
