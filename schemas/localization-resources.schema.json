{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/localization-resources.schema.json",
  "title": "TraceCue Localization Resources",
  "type": "object",
  "required": [
    "schema_version",
    "resources_version",
    "generated_at",
    "locale_selection",
    "baseline_locale",
    "supported_locale_count",
    "key_inventory",
    "selected_resource",
    "locale_resources",
    "fallback",
    "rtl_layout_guard",
    "raw_evidence_policy",
    "boundary"
