  "properties": {
    "schema_version": { "type": "string" },
    "resources_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "locale_selection": { "type": "string" },
    "baseline_locale": { "type": "string" },
    "supported_locale_count": { "type": "number" },
    "key_inventory": { "type": "array" },
    "selected_resource": { "type": "object" },
    "locale_resources": { "type": "array" },
    "fallback": { "type": "object" },
    "rtl_layout_guard": { "type": "object" },
    "raw_evidence_policy": { "type": "object" },
    "boundary": { "type": "object" }
